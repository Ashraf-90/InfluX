@model InfluX.Models.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2>@ViewData["Title"]</h2>
        <form asp-action="Login" asp-controller="Account" method="post" asp-route-returnUrl="@returnUrl">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-floating mb-2">
                <input asp-for="UserNameOrEmail" class="form-control" placeholder=" " autocomplete="username" />
                <label asp-for="UserNameOrEmail"></label>
                <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
            </div>
            <div class="form-floating mb-2">
                <input asp-for="Password" class="form-control" placeholder=" " autocomplete="current-password" />
                <label asp-for="Password"></label>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            <button type="submit" class="btn btn-primary w-100">تسجيل الدخول</button>
        </form>
        <p class="mt-3">
            لا تملك حساباً؟ <a asp-action="Register" asp-route-returnUrl="@returnUrl">إنشاء حساب</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
