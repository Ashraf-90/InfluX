@model InfluX.Models.RegisterViewModel
@{
    ViewData["Title"] = "إنشاء حساب";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2>@ViewData["Title"]</h2>
        <form asp-action="Register" asp-controller="Account" method="post" asp-route-returnUrl="@returnUrl">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-floating mb-2">
                <input asp-for="Email" class="form-control" placeholder=" " autocomplete="username" />
                <label asp-for="Email"></label>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-2">
                <input asp-for="UserName" class="form-control" placeholder=" " autocomplete="username" />
                <label asp-for="UserName"></label>
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-2">
                <input asp-for="DisplayName" class="form-control" placeholder=" " />
                <label asp-for="DisplayName"></label>
                <span asp-validation-for="DisplayName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-2">
                <input asp-for="Password" class="form-control" placeholder=" " autocomplete="new-password" />
                <label asp-for="Password"></label>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="ConfirmPassword" class="form-control" placeholder=" " autocomplete="new-password" />
                <label asp-for="ConfirmPassword"></label>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100">إنشاء الحساب</button>
        </form>
        <p class="mt-3">
            لديك حساب؟ <a asp-action="Login" asp-route-returnUrl="@returnUrl">تسجيل الدخول</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
